{
  "name": "photopti",
  "productName": "Photopti",
  "version": "1.0.0",
  "description": "A desktop app for batch image optimization and precise cover-image cropping.",
  "homepage": "https://github.com/adamaoc/photopti-app#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adamaoc/photopti-app.git"
  },
  "bugs": {
    "url": "https://github.com/adamaoc/photopti-app/issues"
  },
  "keywords": ["electron", "image-optimization", "image-resize", "photo", "sharp"],
  "engines": {
    "node": ">=20"
  },
  "main": "main.js",
  "build": {
    "appId": "com.adamaoc.photopti",
    "productName": "Photopti",
    "icon": "assets/logo-lg-200.png",
    "asarUnpack": [
      "**/node_modules/sharp/**",
      "**/node_modules/@img/**"
    ],
    "npmRebuild": false,
    "files": [
      "main.js",
      "main-process/**/*",
      "preload.js",
      "renderer/**/*"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "logo-lg-200.png"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.photography",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/photopti.icns",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "afterSign": "build/notarize.js",
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ],
      "category": "Graphics",
      "maintainer": "ampnet media <hello@ampnet.media>"
    }
  },
  "author": {
    "name": "ampnet media",
    "email": "hello@ampnet.media",
    "url": "https://ampnet.media"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder -mwl",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "lint": "node scripts/check-syntax.js",
    "test": "node --test",
    "check": "npm run lint && npm test"
  },
  "dependencies": {
    "heic-convert": "^2.1.0",
    "sharp": "^0.33.4"
  },
  "devDependencies": {
    "@electron/notarize": "^2.2.0",
    "electron": "^42.5.1",
    "electron-builder": "^24.13.3"
  }
}
